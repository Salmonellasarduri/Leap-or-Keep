alvage_card:u10","enemy_turn","drift","pair:u9:top:u10","act:1:ship:multi:lv1,lv2","clear_continue","camp_resupply","route_danger","loadout:u10,u6,u9,u3,u5,u1","pair:u3:top:u10","act:0:drone:cell:2,3:right","act:1:drone:multi:e0","commit","enemy_turn","damage_hp","drift","pair:u5:bottom:u9","act:1:drone:dir:up","act:0:ship:go","commit","enemy_turn","damage_hp","damage_hp","drift","pair:u1:bottom:u6","act:0:drone:go","act:1:ship:cell:2,1:right","commit","enemy_turn","drift","rest_choose:u3","enemy_turn","drift","pair:u6:top:u9","act:0:ship:cell:2,1:left","fizzle:1","commit","enemy_turn","drift","pair:u5:top:u10","act:0:drone:stay","act:1:drone:multi:e1","clear_continue","relic_seal","keep"],"agentChoiceProfile":{"schema":"lok_choice_profile/1.0","total":110,"tag_counts":{"pair":21,"attack":32,"position":40,"action":38,"move_choice":15,"enemy_target":10,"causes_damage":8,"lethal":5,"progress":18,"takes_damage":14,"resource_preserve":14,"high_stakes":24,"repair":5,"camp":3,"route":3,"risk":4,"temptation":4,"upside":4,"hazard_target":1,"avoids_damage":9,"relic":3,"resource_loss":4,"multi_target":6,"resource":2,"control":6,"rest":3,"safe":3,"low_value":2,"burns_card":2,"brake":1,"no_effect":1},"bucket_counts":{"pair:attack+move":5,"act:position":10,"act:attack:lethal":5,"commit":17,"damage_hp":14,"act:attack":10,"salvage_repair":3,"camp_upgrade":2,"route_danger":3,"act:avoids_damage:position":9,"pair:attack+brake_move":3,"relic_deploy":1,"pair:attack_multi+brake_move":2,"pair:attack+ram":2,"salvage_card":2,"pair:move+push":3,"act:control":3,"rest_choose":3,"pair:attack_multi+move":3,"relic_seal":2,"fizzle:1":2,"pair:attack_multi+ram":1,"camp_resupply":1,"pair:heal+ram":1,"act:repair":1,"pair:attack_all+move":1,"keep":1}},"says":[{"at":0,"text":"初手は算数だ。ドローン前進+斉射でe0は消える。旗艦の1点は保険料として払う"},{"at":0,"text":"初手は算数だ。ドローン前進+零距離斉射でe0は消える。旗艦の1点は保険料として払う"},{"at":1,"text":"初手は算数だ。ドローン前進+零距離斉射でe0は消える。旗艦の1点は保険料として払う"},{"at":5,"text":"満タンの1点はカードより安い。受けて、次のラウンドで返す"},{"at":8,"text":"宇宙に壁はない。お前の慣性とうちのドローンの慣性は、次のラウンド(4,0)で待ち合わせだ"},{"at":12,"text":"この1点も織り込み済み。パッチで返してもらう"},{"at":14,"text":"衝突の1点はドローンの仕事代だ"},{"at":15,"text":"残骸からは装甲を剥ぐ。船体はゾーンを跨ぐ通貨だ"},{"at":17,"text":"回復は保険、強化は複利。押しの一手を買う"},{"at":18,"text":"ボマーは歩く機雷だ。敵の群れに押し返せば、向こうの武器はこっちの花火になる"},{"at":19,"text":"編成は物理特化: 押しのリパルサー+、突進のラム、締めの零距離。ボマーは触らず転がす"},{"at":20,"text":"予告制の敵は未来を確定してくれる。空振り確定の一撃ほど安い保険はない"},{"at":26,"text":"ボマーの爆風は上端を回って(1,0)のお前の相棒に届く。俺は1歩ずれて、零距離でもう1機を頂く。全部、お前らの武器だ"},{"at":31,"text":"同士討ちの残骸から装甲を頂く。8/8、貸し借りなしだ"},{"at":33,"text":"金庫の5より、9ゾーン分の複利を取る。遺物は使ってこそ遺物だ"},{"at":34,"text":"殲滅プロトコルの声とやらを聞いてやる。ウォーデン相手は撃つな、ぶつけろ"},{"at":35,"text":"お前の来る椅子には俺が座る。殲滅プロトコルは静かな声だ — 斜め、壁越し、2体まで。良い買い物だった"},{"at":37,"text":"2体まで撃てるなら、1発は道路工事に使う。岩をどかして右の航路を開ける"},{"at":41,"text":"甲殻は零距離の飽和火力で割る。もう1機は船体そのものが弾丸だ — 物理に装甲は関係ない"},{"at":43,"text":"甲殻は零距離で割った。もう1機は船体が弾丸だ — 物理に装甲は関係ない"},{"at":44,"text":"残骸から拾うのは、もちろんお前だ殲滅プロトコル。まだ聞きたい声がある"},{"at":46,"text":"遺物に磨きをかける。死んだ文明の声を、もう少し大きく"},{"at":47,"text":"メンダー入りは面倒だが、レア遺物の期待値が勝る。回復役から順に消す、それだけだ"},{"at":48,"text":"物理と多重射撃の編成続行。パッチは温存、次に効かせる"},{"at":49,"text":"回復役から消すのは礼儀だ。移動3は殲滅プロトコルの脚 — 死んだ文明は速い"},{"at":54,"text":"海賊の挨拶は装甲で受ける。カードは命、HPは経費だ"},{"at":58,"text":"押しの向きを読み違えた。ドローンに詫びる — この1点は俺の授業料だ"},{"at":63,"text":"甲殻には船体を、海賊には弾を。それぞれに効く言語で話す"},{"at":67,"text":"また装甲を剥いで貼る。うちの船は敵の甲羅でできていく"},{"at":69,"text":"取り立てた装甲を1枚返す。差し引きゼロなら悪くない商売だ"},{"at":71,"text":"運任せは1/6で遺物を燃やす。制御には金を払う主義だ — フルリバース、いい制動だった"},{"at":73,"text":"休息中の流れ弾。それでも遺物は守った — 安い"},{"at":76,"text":"殲滅プロトコルの声はドローンからも聞こえる。海賊、商談は終わりだ"},{"at":78,"text":"複利は1本あれば十分。こっちは金庫だ — 帰る理由は多いほどいい"},{"at":79,"text":"ボス前章。物理キット+パッチで整える"},{"at":80,"text":"巡回路ごと消す。触手は美しいが、美術品は墓標に飾っておけ"},{"at":86,"text":"二丁の銃口が同じマスを見てる時点で、そのマスは俺のものじゃない"},{"at":92,"text":"割れる奴は近くで割らない。まず間合いを作る — 分裂は距離の中でしか処理できない"},{"at":97,"text":"経費計上。次のラウンドで休息と回収だ"},{"at":99,"text":"また制御に1点払う。デスロール、看板カードだが物理は間に合ってる"},{"at":102,"text":"5発は撃たせすぎた。殲滅プロトコル — 間合い2の商売人に、射程2の返事だ"},{"at":104,"text":"5発は撃たせすぎた。殲滅プロトコル — 間合い2の商売人に、射程2の返事だ"},{"at":105,"text":"慣性の流れ弾まで俺の味方か。ゼロ距離でお別れだ、商売人"},{"at":111,"text":"割れる奴は機雷で割る。分裂の権利ごと爆風に置いてこい"},{"at":113,"text":"割れる奴は機雷で割る。分裂の権利ごと爆風に置いてこい"},{"at":118,"text":"欠片が2つ、射程に2つ。殲滅プロトコルは複数形が得意だ"},{"at":119,"text":"旗艦の主砲で二匹まとめて。掃除まで含めて戦術だ"},{"at":121,"text":"ボスの前では投資より生存。全部直せ、墓所の主に会いに行く"},{"at":122,"text":"主の寝室まで来て土産をケチる理由がない。採掘機1機は誤差だ"},{"at":123,"text":"ボス編成: 殲滅+、押し、突進、零距離、パッチ、そして切り札の自爆ドローン"},{"at":124,"text":"初手から本体に3点。お前の産む機雷は、全部お前に返す予定だ"},{"at":133,"text":"回避不能なら装甲を厚くして受ける。ドローンは本体に船体語で挨拶だ"},{"at":139,"text":"切り札は王を買うために燃やす。殲滅プロトコルの声の主に、うちの一番うるさい花火を聞かせてやれ"},{"at":145,"text":"3度目の自選。制御に払った合計3点、後悔はひとつもない"},{"at":148,"text":"戦利品が先、戦果は後。箱の上で〆る"},{"at":155,"text":"箱ひとつに未練は持たない。閉店だ、採掘屋"},{"at":158,"text":"3つ目は金庫へ。帰り道の重さがちょうどいい"},{"at":159,"text":"『もう一回だけ跳ぶ』は、次の航海の俺に言わせる。今日は王を討った。生きて帰ることまでが狩りだ"}],"wows":[{"z":1,"e":0,"r":3,"text":"衝突の1点はドローンの仕事代だ"}]}